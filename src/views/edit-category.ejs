<%- include('partials/header') %>

    <main>
        <h1>
            Edit Category
        </h1>
        
        <p><strong>Category Name:</strong></p>
        
        <form action="/edit-category/<%= category.category_id %>" method="POST">
        
            <div class="form-group">
                <label>
                    <input type="text" name="category_name" placeholder="Enter a new category name" value="<%= category.name %>" maxlength="100" required>
                </label>
            </div>
        
            <button type="submit">Update Category</button>
        </form>
        
        
        <p><a href="/categories">← Back to Categories</a></p>
    </main>

    <%- include('partials/footer') %>