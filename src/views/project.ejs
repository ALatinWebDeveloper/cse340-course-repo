<%- include('partials/header') %>

    <main>
        <h1>
            <%= project.title %>
        </h1>

        <p><strong>Date:</strong>
            <%= new Date(project.date).toLocaleDateString('en-US', { year: 'numeric' , month: 'long' , day: 'numeric' })
                %>
        </p>

        <p><strong>Location:</strong>
            <%= project.location %>
        </p>

        <p><strong>Description:</strong>
            <%= project.description %>
        </p>

        <p><strong>Partner Organization:</strong>
            <a href="/organization/<%= project.organization_id %>">
                <%= project.organization_name %>
            </a>
        </p>

        <p><strong>Categories:</strong>
            <% if (categories && categories.length> 0) { %>
                <% categories.forEach((cat, index)=> { %>
                    <a href="/category/<%= cat.category_id %>">
                        <%= cat.name %>
                    </a>
                    <% if (index < categories.length - 1) { %>, <% } %>
                            <% }) %>
                                <% } else { %>
                                    No categories assigned.
                                    <% } %>
        </p>

        <% if (user && user.role_name==='admin' ) { %>
            <a href="/assign-categories/<%= project.project_id %>">Edit Categories</a>
            <p><a href="/edit-project/<%= project.project_id %>">Edit this Project</a></p>
            <% } %>

                <!-- Show volunteer functionality only if logged in -->
                <% if (user) { %>
                    <div class="volunteer-section">
                        <% if (volunteer && user) { %>
                            <p>✅ <strong>You are volunteering for this project.</strong></p>
                            <form action="/project/<%= project.project_id %>/unvolunteer" method="POST">
                                <button type="submit" class="btn-remove">Remove my sign-up</button>
                            </form>
                            <% } else { %>
                                <form action="/project/<%= project.project_id %>/volunteer" method="POST">
                                    <button type="submit" class="btn-volunteer">Sign Up to Volunteer</button>
                                </form>
                                <% } %>
                    </div>
                    <% } %>

                        <p><a href="/projects">← Back to Upcoming Projects</a></p>
    </main>

    <%- include('partials/footer') %>