<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>

        <p>Here are a few of our service projects:</p>
        <ul>

            <% projects.forEach(project=> { %>
                <li>
                    <%= New Date(project.event_date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %> -
                    <strong><%= project.title %></strong>
                    <p><%= project.organization_name %></p>
                </li>
                <% }); %>
        </ul>
    </main>

    <%- include('partials/footer') %>