<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>

        <p>Here are a few of our service projects:</p>
        <ul>
            <% projects.forEach(project=> { %>
                <li>
                    <%= new Date(project.event_date).toLocaleDateString('en-US', { year: 'numeric' , month: 'long' ,
                        day: 'numeric' }) %>:
                        <%= project.title %>
                            (<%= project.title %>)
                </li>
                <% }) %>
        </ul>
    </main>

    <%- include('partials/footer') %>