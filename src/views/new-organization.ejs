<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>

        <form action="/new-organization" method="POST">
            <div class="form-group">
                <label maxlength="150" for="name" required>Organization Name</label>
                <input type="text" id="name" name="name" required />
            </div>

            <div class="form-group">
                <label for="description" required>Description</label>
                <textarea id="description" name="description" maxlength="500" required></textarea>
            </div>

            <div class="form-group">
                <label for="contactEmail" required>Contact Email</label>
                <input type="email" id="contactEmail" name="contactEmail" required/>
            </div>

            <button type="submit">Create Organization</button>
        </form>

    </main>
    <%- include('partials/footer') %>